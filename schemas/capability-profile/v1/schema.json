{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://myx.sh/schemas/capability-profile/v1/schema.json",
  "title": "Capability Profile v1",
  "type": "object",
  "required": ["schema_version", "identity", "tools", "permissions"],
  "properties": {
    "schema_version": { "type": "string", "const": "1" },
    "identity": {
      "type": "object",
      "required": ["name", "version"],
      "properties": {
        "name": { "type": "string", "minLength": 1 },
        "version": { "type": "string", "minLength": 1 },
        "publisher": { "type": "string" },
        "license": { "type": "string" }
      }
    },
    "metadata": {
      "type": "object",
      "properties": {
        "description": { "type": "string" },
        "homepage": { "type": "string" },
        "source": { "type": "string" }
      }
    },
    "capabilities": {
      "type": "array",
      "items": { "type": "string" }
    },
    "instructions": {
      "type": "object",
      "properties": {
        "system": { "type": "string" },
        "usage": { "type": "string" }
      }
    },
    "tools": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["name", "tool_class", "execution"],
        "properties": {
          "name": { "type": "string", "minLength": 1 },
          "description": { "type": "string" },
          "parameters": {},
          "tool_class": {
            "type": "string",
            "enum": ["http_api", "local_process", "filesystem_assisted", "composite"]
          },
          "execution": {
            "oneOf": [
              {
                "type": "object",
                "required": ["kind", "method", "url"],
                "properties": {
                  "kind": { "const": "http" },
                  "method": { "type": "string", "minLength": 1 },
                  "url": { "type": "string", "minLength": 1 },
                  "headers": {
                    "type": "object",
                    "additionalProperties": { "type": "string" }
                  },
                  "timeout_ms": { "type": ["integer", "null"], "minimum": 1 }
                },
                "additionalProperties": false
              },
              {
                "type": "object",
                "required": ["kind", "command", "timeout_ms"],
                "properties": {
                  "kind": { "const": "subprocess" },
                  "command": {
                    "type": "string",
                    "minLength": 1,
                    "pattern": "^[^/\\\\\\s]+$"
                  },
                  "args": {
                    "type": "array",
                    "items": { "type": "string" }
                  },
                  "cwd": { "type": ["string", "null"] },
                  "env_passthrough": {
                    "type": "array",
                    "items": { "type": "string" }
                  },
                  "timeout_ms": { "type": "integer", "minimum": 1 }
                },
                "additionalProperties": false
              }
            ]
          }
        }
      }
    },
    "permissions": {
      "type": "object",
      "required": ["network", "secrets", "filesystem", "subprocess"],
      "properties": {
        "network": {
          "type": "array",
          "items": { "type": "string" }
        },
        "secrets": {
          "type": "array",
          "items": { "type": "string" }
        },
        "filesystem": {
          "type": "object",
          "required": ["read", "write"],
          "properties": {
            "read": { "type": "array", "items": { "type": "string" } },
            "write": { "type": "array", "items": { "type": "string" } }
          }
        },
        "subprocess": {
          "type": "object",
          "required": ["allowed_commands", "allowed_cwds", "allowed_env"],
          "properties": {
            "allowed_commands": {
              "type": "array",
              "items": { "type": "string" }
            },
            "allowed_cwds": {
              "type": "array",
              "items": { "type": "string" }
            },
            "allowed_env": {
              "type": "array",
              "items": { "type": "string" }
            },
            "max_timeout_ms": { "type": ["integer", "null"], "minimum": 1 }
          }
        }
      }
    },
    "compatibility": {
      "type": "object",
      "properties": {
        "runtimes": {
          "type": "array",
          "items": { "type": "string" }
        },
        "platforms": {
          "type": "array",
          "items": { "type": "string" }
        }
      }
    }
  }
}
