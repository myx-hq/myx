{
  "schema_version": "1",
  "identity": {
    "name": "github",
    "version": "0.1.0",
    "publisher": "example",
    "license": "Apache-2.0"
  },
  "metadata": {
    "description": "GitHub capability bundle for myx example."
  },
  "capabilities": [
    "search_repositories"
  ],
  "instructions": {
    "system": "Use the GitHub capability to search repositories when the user asks about code, repos, or maintainers.",
    "usage": "Call search_repositories with a focused query and summarize key repository metadata."
  },
  "tools": [
    {
      "name": "search_repositories",
      "description": "Search GitHub repositories by query text.",
      "parameters": {
        "type": "object",
        "properties": {
          "query": {
            "type": "string",
            "description": "Search term for repository queries."
          }
        },
        "required": [
          "query"
        ]
      },
      "tool_class": "http_api",
      "execution": {
        "kind": "http",
        "method": "GET",
        "url": "https://api.github.com/search/repositories?q={{query}}",
        "timeout_ms": 10000
      }
    }
  ],
  "permissions": {
    "network": [
      "api.github.com"
    ],
    "secrets": [
      "GITHUB_TOKEN"
    ],
    "filesystem": {
      "read": [],
      "write": []
    },
    "subprocess": {
      "allowed_commands": [],
      "allowed_cwds": [],
      "allowed_env": [],
      "max_timeout_ms": 10000
    }
  },
  "compatibility": {
    "runtimes": [
      "openai",
      "skill",
      "mcp"
    ],
    "platforms": [
      "darwin",
      "linux"
    ]
  }
}
